{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "lantern",
  "homepage": "https://lantern-registry.vercel.app",
  "items": [
    {
      "name": "theme-lantern",
      "type": "registry:theme",
      "title": "Lantern Theme",
      "description": "Lantern design tokens: CSS variables for shadcn slots (light). cssVars are generated by scripts/sync-tokens.mjs.",
      "cssVars": {
        "light": {
          "background": "0 0% 100%",
          "foreground": "0 0% 3.9%",
          "card": "0 0% 100%",
          "card-foreground": "0 0% 3.9%",
          "popover": "0 0% 100%",
          "popover-foreground": "0 0% 3.9%",
          "primary": "258.8 63.3% 59.4%",
          "primary-foreground": "0 0% 98%",
          "secondary": "0 0% 96.1%",
          "secondary-foreground": "0 0% 9%",
          "muted": "0 0% 96.1%",
          "muted-foreground": "0 0% 45.1%",
          "accent": "267.7 95.1% 92%",
          "accent-foreground": "259.8 76.6% 69.8%",
          "destructive": "0 72.2% 50.6%",
          "destructive-foreground": "0 0% 100%",
          "border": "0 0% 89.8%",
          "input": "0 0% 89.8%",
          "ring": "0 0% 83.1%",
          "tooltip": "0 0% 0%",
          "tooltip-foreground": "0 0% 100%",
          "sidebar": "0 0% 98%",
          "sidebar-foreground": "0 0% 25.1%",
          "sidebar-primary": "0 0% 9%",
          "sidebar-primary-foreground": "0 0% 98%",
          "sidebar-accent": "0 0% 96.1%",
          "sidebar-accent-foreground": "0 0% 9%",
          "sidebar-border": "0 0% 89.8%",
          "sidebar-ring": "0 0% 83.1%",
          "radius": "0.625rem"
        }
      },
      "tailwind": {
        "config": {
          "theme": {
            "extend": {
              "colors": {
                "violet": {
                  "50": "#fcfaff",
                  "100": "#f9f5ff",
                  "200": "#f4ebff",
                  "300": "#e9d7fe",
                  "400": "#d6bbfb",
                  "500": "#b692f6",
                  "600": "#9e77ed",
                  "700": "#7f56d9",
                  "800": "#6941c6",
                  "900": "#53389e",
                  "950": "#42307d"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Utils",
      "description": "The cn() utility for merging Tailwind classes.",
      "dependencies": [
        "clsx",
        "tailwind-merge"
      ],
      "files": [
        {
          "path": "registry/default/lib/utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "Button with variants (default, destructive, outline, secondary, ghost, link).",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": ["@lantern/utils"],
      "files": [{ "path": "registry/default/ui/button.tsx", "type": "registry:ui" }]
    },
    {
      "name": "separator",
      "type": "registry:ui",
      "title": "Separator",
      "description": "Visually or semantically separates content.",
      "dependencies": ["@radix-ui/react-separator"],
      "registryDependencies": ["@lantern/utils"],
      "files": [{ "path": "registry/default/ui/separator.tsx", "type": "registry:ui" }]
    },
    {
      "name": "tooltip",
      "type": "registry:ui",
      "title": "Tooltip",
      "description": "Tooltip styled with the Lantern tooltip tokens (dark background).",
      "dependencies": ["@radix-ui/react-tooltip"],
      "registryDependencies": ["@lantern/utils", "@lantern/theme-lantern"],
      "files": [{ "path": "registry/default/ui/tooltip.tsx", "type": "registry:ui" }]
    },
    {
      "name": "sheet",
      "type": "registry:ui",
      "title": "Sheet",
      "description": "Side panel built on Radix Dialog.",
      "dependencies": ["@radix-ui/react-dialog", "class-variance-authority", "lucide-react"],
      "registryDependencies": ["@lantern/utils"],
      "files": [{ "path": "registry/default/ui/sheet.tsx", "type": "registry:ui" }]
    },
    {
      "name": "skeleton",
      "type": "registry:ui",
      "title": "Skeleton",
      "description": "Loading placeholder.",
      "registryDependencies": ["@lantern/utils"],
      "files": [{ "path": "registry/default/ui/skeleton.tsx", "type": "registry:ui" }]
    },
    {
      "name": "use-mobile",
      "type": "registry:hook",
      "title": "useIsMobile",
      "description": "Hook that reports whether the viewport is below the mobile breakpoint.",
      "files": [{ "path": "registry/default/hooks/use-mobile.ts", "type": "registry:hook" }]
    },
    {
      "name": "sidebar",
      "type": "registry:ui",
      "title": "Sidebar",
      "description": "Composable, collapsible Lantern sidebar (265px expanded, 60px icon rail). Based on the shadcn sidebar API: SidebarProvider, Sidebar, SidebarTrigger, SidebarHeader/Content/Footer, SidebarGroup, SidebarMenu and friends.",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority", "lucide-react"],
      "registryDependencies": [
        "@lantern/utils",
        "@lantern/theme-lantern",
        "@lantern/button",
        "@lantern/separator",
        "@lantern/sheet",
        "@lantern/skeleton",
        "@lantern/tooltip",
        "@lantern/use-mobile"
      ],
      "files": [{ "path": "registry/default/ui/sidebar.tsx", "type": "registry:ui" }]
    },
    {
      "name": "icons",
      "type": "registry:ui",
      "title": "Icons",
      "description": "The Lantern icon set: product icons exported from Figma plus the curated Lucide subset re-exported from lucide-react.",
      "dependencies": [
        "lucide-react"
      ],
      "files": [
        {
          "path": "registry/default/icons/index.ts",
          "type": "registry:ui",
          "target": "components/icons/index.ts"
        },
        {
          "path": "registry/default/icons/types.ts",
